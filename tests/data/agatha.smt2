(set-info :smt-lib-version 2.6)
(set-logic UF)
(declare-sort $$unsorted 0)
(declare-fun tptp.lives ($$unsorted) Bool)
(declare-fun tptp.agatha () $$unsorted)
(declare-fun tptp.killed ($$unsorted $$unsorted) Bool)
(assert (exists ((X $$unsorted)) (and (tptp.lives X) (tptp.killed X tptp.agatha))))
(assert (tptp.lives tptp.agatha))
(declare-fun tptp.butler () $$unsorted)
(assert (tptp.lives tptp.butler))
(declare-fun tptp.charles () $$unsorted)
(assert (tptp.lives tptp.charles))
(assert (forall ((X $$unsorted)) (=> (tptp.lives X) (or (= X tptp.agatha) (= X tptp.butler) (= X tptp.charles)))))
(declare-fun tptp.hates ($$unsorted $$unsorted) Bool)
(assert (forall ((X $$unsorted) (Y $$unsorted)) (=> (tptp.killed X Y) (tptp.hates X Y))))
(declare-fun tptp.richer ($$unsorted $$unsorted) Bool)
(assert (forall ((X $$unsorted) (Y $$unsorted)) (=> (tptp.killed X Y) (not (tptp.richer X Y)))))
(assert (forall ((X $$unsorted)) (=> (tptp.hates tptp.agatha X) (not (tptp.hates tptp.charles X)))))
(assert (forall ((X $$unsorted)) (=> (not (= X tptp.butler)) (tptp.hates tptp.agatha X))))
(assert (forall ((X $$unsorted)) (=> (not (tptp.richer X tptp.agatha)) (tptp.hates tptp.butler X))))
(assert (forall ((X $$unsorted)) (=> (tptp.hates tptp.agatha X) (tptp.hates tptp.butler X))))
(assert (forall ((X $$unsorted)) (exists ((Y $$unsorted)) (not (tptp.hates X Y)))))
(assert (not (= tptp.agatha tptp.butler)))
(assert (not (tptp.killed tptp.agatha tptp.agatha)))
(set-info :filename agatha)
(check-sat-assuming ( true ))

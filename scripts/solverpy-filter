#!/usr/bin/env python3

def arguments():
   import argparse
   parser = argparse.ArgumentParser(description=
      "Filter positive/negative training samples by ratio.")
   parser.add_argument("input", metavar="input.in",
      help="Input training file (plain or compressed).")
   parser.add_argument("output", metavar="output.in", nargs="?", default=None,
      help="Output file (default: overwrite input).")
   parser.add_argument("--ratio", type=float, metavar="r", required=True,
      help="Max neg/pos ratio (>0) or max pos/neg ratio as negative value (<0).")
   parser.add_argument("--seed", type=int, metavar="s", default=0,
      help="Random seed for sampling (default: 0).")
   parser.add_argument("-v", "--verbose", action="store_true",
      help="Show debug details.")
   return parser.parse_args()

def main(f_in, f_out, ratio, seed):
   import random
   import numpy
   from solverpy_learn.builder import svm

   (xs, ys) = svm.load(f_in)

   pos_idx = numpy.where(ys == 1)[0]
   neg_idx = numpy.where(ys == 0)[0]

   random.seed(seed)
   if ratio > 0 and len(pos_idx) * ratio < len(neg_idx):
      neg_idx = numpy.array(random.sample(list(neg_idx), int(len(pos_idx) * ratio)))
   elif ratio < 0 and len(neg_idx) * (-ratio) < len(pos_idx):
      pos_idx = numpy.array(random.sample(list(pos_idx), int(len(neg_idx) * (-ratio))))

   keep = numpy.sort(numpy.concatenate([pos_idx, neg_idx]))
   svm.save(xs[keep], ys[keep], f_out)

if __name__ == "__main__":
   import logging
   args = arguments()
   level = logging.DEBUG if args.verbose else logging.INFO
   logging.basicConfig(level=level, format="%(message)s")
   main(args.input, args.output or args.input, args.ratio, args.seed)
